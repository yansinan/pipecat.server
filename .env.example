# Pipecat 语音 Agent 环境变量模板

# ===== LLM (OpenAI-compatible via Headroom / LiteLLM) =====
LLM_BASE_URL=http://serverhome.tail2e6efb.ts.net/litellm/headroom/v1/
LLM_API_KEY=*** placeholder key (Headroom injects the real one)
LLM_MODEL=minimax

# ===== TTS (Edge TTS, Microsoft online, free) =====
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_RATE=+0%
TTS_VOLUME=+0%

# ===== STT (local Whisper) =====
WHISPER_MODEL_SIZE=small            # tiny | base | small | medium | large-v3
WHISPER_CACHE_DIR=./cache/whisper

# ===== VAD (local Silero ONNX) =====
SILERO_CACHE_DIR=./cache/silero

# ===== Transport =====
TRANSPORT=webrtc                    # current default is FastAPI WebSocket
HOST=0.0.0.0
PORT=8765